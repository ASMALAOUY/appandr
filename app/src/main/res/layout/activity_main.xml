<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD AJOUTER -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SectionTitle"
                        android:text="@string/section_add"/>

                    <TextView
                        style="@style/InputLabel"
                        android:text="@string/label_nom"/>
                    <EditText
                        android:id="@+id/nom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:hint="@string/hint_nom"
                        android:inputType="textPersonName"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@android:color/transparent"
                        android:paddingBottom="8dp"
                        android:autofillHints="name"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        style="@style/InputLabel"
                        android:text="@string/label_prenom"/>
                    <EditText
                        android:id="@+id/prenom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:hint="@string/hint_prenom"
                        android:inputType="textPersonName"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@android:color/transparent"
                        android:paddingBottom="8dp"
                        android:autofillHints="name"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="16dp"/>

                    <!-- BOUTONS LISTE + VALIDER -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <Button
                            android:id="@+id/btn_liste"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp"
                            android:text="@string/btn_liste"
                            android:backgroundTint="#E3F2FD"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                        <Button
                            android:id="@+id/bn"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="@string/btn_valider"
                            android:backgroundTint="@color/colorPrimary"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            style="@style/Widget.MaterialComponents.Button"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD RECHERCHER / SUPPRIMER -->
            <androidx.cardview.widget.CardView
                style="@style/CardStyle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SectionTitle"
                        android:text="@string/section_search"/>

                    <TextView
                        style="@style/InputLabel"
                        android:text="@string/label_id"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/id"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="48dp"
                            android:hint="@string/hint_id"
                            android:inputType="number"
                            android:textColor="@color/colorTextPrimary"
                            android:background="@android:color/transparent"
                            android:paddingBottom="8dp"
                            android:autofillHints=""/>

                        <Button
                            android:id="@+id/load"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/colorPrimary"
                            android:text="@string/btn_chercher_short"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            style="@style/Widget.MaterialComponents.Button"/>

                        <Button
                            android:id="@+id/delete"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/colorDanger"
                            android:text="@string/btn_supprimer_short"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            style="@style/Widget.MaterialComponents.Button"/>
                    </LinearLayout>

                    <!-- Résultat -->
                    <LinearLayout
                        android:id="@+id/result_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_result"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/avatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_avatar"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/res"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#0D47A1"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/res_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorPrimary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_found"
                            android:background="@drawable/bg_badge_green"
                            android:textColor="#2E7D32"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STATS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="1dp"
                    app:contentPaddingTop="12dp"
                    app:contentPaddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/stat_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_total"
                            android:textSize="10sp"
                            android:textColor="@color/colorTextSecondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="1dp"
                    app:contentPaddingTop="12dp"
                    app:contentPaddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/stat_added"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorSuccess"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_added"
                            android:textSize="10sp"
                            android:textColor="@color/colorTextSecondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="1dp"
                    app:contentPaddingTop="12dp"
                    app:contentPaddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/stat_deleted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorDanger"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_deleted"
                            android:textSize="10sp"
                            android:textColor="@color/colorTextSecondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>